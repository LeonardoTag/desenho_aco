<UserControl x:Class="CapitalAco.DrawingMacro.App.Views.EditorPecaView"
             xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200"
             Background="#2C3E50"
             Foreground="White">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Painel Esquerdo: Entrada de Segmentos -->
        <Border Grid.Column="0" Background="#34495E" CornerRadius="8" Padding="10" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ADICIONAR SEGMENTO" FontSize="14" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                <!-- Controles de Segmento -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="2">
                        <TextBlock Text="Direção:" Margin="0,0,0,3" FontSize="11" Foreground="#BDC3C7"/>
                        <ComboBox SelectedValue="{Binding SegDirecao}" SelectedValuePath="Content">
                            <ComboBoxItem Content="N"/>
                            <ComboBoxItem Content="E"/>
                            <ComboBoxItem Content="S"/>
                            <ComboBoxItem Content="W"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="2">
                        <TextBlock Text="Ângulo (graus):" Margin="0,0,0,3" FontSize="11" Foreground="#BDC3C7"/>
                        <TextBox Text="{Binding SegAngulo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="2">
                        <TextBlock Text="Medida (mm):" Margin="0,0,0,3" FontSize="11" Foreground="#BDC3C7"/>
                        <TextBox Text="{Binding SegMedida, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="2">
                        <TextBlock Text="Tipo de Medida:" Margin="0,0,0,3" FontSize="11" Foreground="#BDC3C7"/>
                        <ComboBox SelectedValue="{Binding SegTipoMedida}" SelectedValuePath="Content">
                            <ComboBoxItem Content="e" Tag="Externa"/>
                            <ComboBoxItem Content="i" Tag="Interna"/>
                        </ComboBox>
                    </StackPanel>

                    <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Segmento Curvo (Calandra)" IsChecked="{Binding SegEhCurvo}" Margin="2,8,2,2" Foreground="White"/>

                    <!-- Detalhes Calandra -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Visibility="{Binding SegEhCurvo, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#2C3E50" Padding="5" Margin="2,5,2,2" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="2">
                                <TextBlock Text="Raio:" FontSize="10" Foreground="#BDC3C7"/>
                                <TextBox Text="{Binding SegCurvaRaio}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="2">
                                <TextBlock Text="Comprimento:" FontSize="10" Foreground="#BDC3C7"/>
                                <TextBox Text="{Binding SegCurvaComprimento}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="2">
                                <TextBlock Text="Ângulo Curva:" FontSize="10" Foreground="#BDC3C7"/>
                                <TextBox Text="{Binding SegCurvaAngulo}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="2">
                                <TextBlock Text="Tipo Raio:" FontSize="10" Foreground="#BDC3C7"/>
                                <ComboBox SelectedValue="{Binding SegCurvaTipoRaio}" SelectedValuePath="Content" FontSize="11">
                                    <ComboBoxItem Content="externo"/>
                                    <ComboBoxItem Content="interno"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Button Grid.Row="4" Grid.ColumnSpan="2" Content="Adicionar Segmento" Command="{Binding AdicionarSegmentoCommand}" Margin="2,10,2,2" Background="#27AE60" Foreground="White" BorderThickness="0" Height="26"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="SEGMENTOS ADICIONADOS" FontSize="12" FontWeight="Bold" Foreground="#3498DB" Margin="0,10,0,5"/>

                <!-- Tabela de Segmentos -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding Segmentos}" SelectedItem="{Binding SelectedSegmento}" AutoGenerateColumns="False" CanUserAddRows="False" Background="#2C3E50" Foreground="White" RowBackground="#34495E" AlternatingRowBackground="#2C3E50" BorderThickness="0" Margin="0,25,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dir" Binding="{Binding Direcao}" Width="35"/>
                        <DataGridTextColumn Header="Ang" Binding="{Binding Angulo}" Width="45"/>
                        <DataGridTextColumn Header="Medida" Binding="{Binding Medida}" Width="60"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMedida}" Width="40"/>
                        <DataGridTextColumn Header="Curv" Binding="{Binding EhCurvo}" Width="45"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Ações de Tabela -->
                <UniformGrid Grid.Row="3" Columns="2" Margin="0,5,0,0">
                    <Button Content="Limpar Tudo" Command="{Binding LimparSegmentosCommand}" Margin="2" Background="#C0392B" Foreground="White" BorderThickness="0" Height="25"/>
                    <Button Content="Remover Sel." Command="{Binding RemoverSegmentoCommand}" CommandParameter="{Binding SelectedSegmento}" Margin="2" Background="#D35400" Foreground="White" BorderThickness="0" Height="25"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Painel Central: Desenho e Preview -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="85"/>
            </Grid.RowDefinitions>

            <Border Background="#34495E" CornerRadius="8" Padding="5" Grid.Row="0">
                <Image Source="{Binding PreviewImage}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Avisos e BBox -->
            <Border Grid.Row="1" Background="#2C3E50" BorderBrush="#E67E22" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,5,0,0">
                <ListBox ItemsSource="{Binding Avisos}" Background="Transparent" BorderThickness="0" Foreground="#E67E22" FontSize="11"/>
            </Border>
        </Grid>

        <!-- Painel Direito: Configuração da Peça e Gerador -->
        <Grid Grid.Column="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Propriedades da Peça -->
            <Border Background="#34495E" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="PROPRIEDADES DA PEÇA" FontSize="13" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,8"/>
                    <TextBlock Text="Nome da Peça:" FontSize="10" Foreground="#BDC3C7"/>
                    <TextBox Text="{Binding NomePeca, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

                    <TextBlock Text="Comprimento (mm):" FontSize="10" Foreground="#BDC3C7"/>
                    <TextBox Text="{Binding ComprimentoPeca, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

                    <TextBlock Text="Chapa:" FontSize="10" Foreground="#BDC3C7"/>
                    <ComboBox ItemsSource="{Binding Chapas}" SelectedItem="{Binding ChapaSelecionada}" DisplayMemberPath="Codigo" Margin="0,2,0,8"/>

                    <UniformGrid Columns="2" Margin="0,5,0,0">
                        <Button Content="Salvar Biblioteca" Command="{Binding SalvarNaBibliotecaCommand}" Margin="2" Background="#2980B9" Foreground="White" BorderThickness="0" Height="26"/>
                        <Button Content="Ficha Dobra (PDF)" Command="{Binding GerarFichaDobraCommand}" Margin="2" Background="#8E44AD" Foreground="White" BorderThickness="0" Height="26"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Adicionar ao Pedido -->
            <Border Grid.Row="1" Background="#34495E" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ADICIONAR AO PEDIDO" FontSize="13" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Quantidade:" FontSize="10" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding PedidoQuantidade}" Margin="0,2,0,8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Observação:" FontSize="10" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding PedidoObservacao}" Margin="0,2,0,8"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Adicionar à Ordem" Command="{Binding AdicionarAoPedidoCommand}" Background="#27AE60" Foreground="White" BorderThickness="0" Height="26"/>
                </StackPanel>
            </Border>

            <!-- Gerador Boiadeira -->
            <Border Grid.Row="2" Background="#34495E" CornerRadius="8" Padding="10">
                <StackPanel>
                    <TextBlock Text="GERADOR BOIADEIRA" FontSize="13" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="2">
                            <TextBlock Text="Aba (Y):" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraAltura}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="2">
                            <TextBlock Text="Largura (X):" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraLargura}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="2">
                            <TextBlock Text="1° Gomo:" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraPrimeiroGomo}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="2">
                            <TextBlock Text="Gomo Sup:" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraGomoSuperior}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="2">
                            <TextBlock Text="Gomo Inf:" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraGomoInferior}" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="2">
                            <TextBlock Text="N° Gomos:" FontSize="9" Foreground="#BDC3C7"/>
                            <TextBox Text="{Binding BoiadeiraNumGomos}" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Resolver Otimização" Command="{Binding GerarBoiadeiraCommand}" Margin="0,8,0,0" Background="#E67E22" Foreground="White" BorderThickness="0" Height="26"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
