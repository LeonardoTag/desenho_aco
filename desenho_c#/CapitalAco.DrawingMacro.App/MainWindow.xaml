<Window x:Class="CapitalAco.DrawingMacro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        xmlns:views="clr-namespace:CapitalAco.DrawingMacro.App.Views"
        Title="Capital Aço Detalhador" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#1E2022">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CAPITAL AÇO" Foreground="#3498DB" FontSize="28" FontWeight="Bold" FontFamily="Segoe UI"/>
            <TextBlock Text="Sistema de Detalhamento de Dobras e Geração de Pedidos (.NET 8)" Foreground="#95A5A6" FontSize="14" Margin="0,5,0,0" FontFamily="Segoe UI"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="#2C3E50" BorderBrush="#34495E" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Editor de Peça" Background="#34495E" Foreground="White" Padding="12,5">
                <views:EditorPecaView DataContext="{Binding Editor}"/>
            </TabItem>
            <TabItem Header="Biblioteca de Peças" Background="#34495E" Foreground="White" Padding="12,5">
                <views:BibliotecaView DataContext="{Binding Biblioteca}"/>
            </TabItem>
            <TabItem Header="Ordem de Produção" Background="#34495E" Foreground="White" Padding="12,5">
                <views:PedidoView DataContext="{Binding Pedido}"/>
            </TabItem>
            <TabItem Header="Configurações" Background="#34495E" Foreground="White" Padding="12,5">
                <views:ConfiguracaoView DataContext="{Binding Configuracao}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
